class Solution {
    public boolean isAnagram(String s, String t) {
       int a[]=new int[256];
       for(int i=0;i<s.length();i++)
       {
        int b=s.charAt(i);
        a[b]++;
       }
       for(int i=0;i<t.length();i++)
       {
        int b=t.charAt(i);
        a[b]--;
       }
       for(int i=0;i<a.length;i++){
        if(a[i]!=0)
        {
            return false;
        }
       }
       return true;
    }
}
