class Solution {
    public int[] getConcatenation(int[] nums) {
        int a[]=new int[nums.length*2];
        int j=0;
        int i=0;
        while((nums[nums.length-1]!=a[a.length-1])&&(j<a.length))
        {
            a[j]=nums[i];
            if(i==nums.length-1)
            {
                i=-1;
            }
            j++;
            i++;
        }
        return a;
    }
}